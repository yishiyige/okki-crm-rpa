import asyncio
import os
from playwright.async_api import async_playwright

async def clean_up_modals(context, page):
    """
    针对小满顽固弹窗的“点杀”逻辑
    """
    print("[*] 正在尝试通过模拟点击清理弹窗...")

    # 核心逻辑：监听新开启的标签页并自动关闭
    def handle_popup(new_page):
        print(f"[Log] 监测到弹窗试图打开新标签页，已拦截并关闭。")
        new_page.close()

    context.on("page", handle_popup)

    try:
        # 1. 尝试寻找那个蓝色的“查看报告”按钮 (支持主页面和 Iframe)
        # 我们用一个通用的逻辑覆盖所有 frame
        found = False
        for frame in page.frames:
            # 搜索包含“查看报告”的按钮
            btn = frame.get_by_text("查看报告", exact=False)
            if await btn.is_visible():
                await btn.click(force=True)
                print("[+] 已点击“查看报告”按钮。")
                found = True
                break
        
        if not found:
            # 2. 如果没找到按钮，强力寻找右上角的关闭图标 (通常是 ant-modal-close)
            for frame in page.frames:
                close_icon = frame.locator(".ant-modal-close, .ant-modal-close-x, [aria-label='Close']")
                if await close_icon.is_visible():
                    await close_icon.first.click(force=True)
                    print("[+] 已点击右上角关闭图标。")
                    found = True
                    break

        if not found:
            print("[!] 未探测到明显的弹窗按钮，尝试最后的 ESC 键强制退出...")
            await page.keyboard.press("Escape")

    except Exception as e:
        print(f"[!] 清理过程发生异常: {e}")
    
    # 给一点缓冲时间让页面恢复响应
    await asyncio.sleep(1)
    # 移除监听，避免影响后续正常的操作
    context.remove_listener("page", handle_popup)

async def check_login():
    user_data = os.path.join(os.environ['LOCALAPPDATA'], r"Microsoft\Edge\User Data\Automation")
    edge_path = r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe"

    async with async_playwright() as p:
        # 注意：这里添加了慢速模式，方便观察
        context = await p.chromium.launch_persistent_context(
            user_data_dir=user_data,
            executable_path=edge_path,
            headless=False,
            no_viewport=True,
            args=["--no-first-run", "--disable-blink-features=AutomationControlled"]
        )
        
        page = context.pages[0]
        await page.goto("https://crm.xiaoman.cn/product")
        
        print("\n" + "="*40)
        print("【操作指引】")
        print("1. 请确保已登录。")
        print("2. 看到那个“3月团队报告”弹窗后。")
        print("3. 回到这里输入 'c' 并回车执行清理。")
        print("="*40)
        
        while True:
            cmd = input("\n>>> 输入 'c' 清理弹窗 / 按 'Enter' 直接退出: ").lower()
            if cmd == 'c':
                # 注意这里传入了 context 和 page
                await clean_up_modals(context, page)
            else:
                break
            
        await context.close()

if __name__ == "__main__":
    # 运行前务必确保关闭所有 Edge 进程
    # Stop-Process -Name "msedge" -Force (在 PowerShell 运行)
    asyncio.run(check_login())