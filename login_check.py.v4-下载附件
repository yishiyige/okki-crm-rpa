import asyncio
import os
import sys
import re
from playwright.async_api import async_playwright

# ================= 配置区 =================
EDGE_PATH = r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe"
USER_DATA_PATH = os.path.join(os.environ['LOCALAPPDATA'], r"Microsoft\Edge\User Data\Automation")
DOWNLOAD_DIR = os.path.join(os.getcwd(), "downloads")
# ==========================================

async def auto_clean_modals(page):
    try:
        await page.evaluate("""() => {
            const selectors = ['.ant-modal-root', '.ant-modal-mask', '.xm-notification', '.ant-modal-wrap'];
            selectors.forEach(s => {
                const el = document.querySelector(s);
                if(el) el.remove();
            });
            document.body.style.overflow = 'auto';
        }""")
    except: pass

async def run_product_task(product_id):
    os.makedirs(DOWNLOAD_DIR, exist_ok=True)

    async with async_playwright() as p:
        print(f"[*] 启动 Edge 自动化实例...")
        context = await p.chromium.launch_persistent_context(
            user_data_dir=USER_DATA_PATH, executable_path=EDGE_PATH,
            headless=False, no_viewport=True,
            accept_downloads=True,
            args=["--no-first-run", "--disable-blink-features=AutomationControlled"]
        )
        page = context.pages[0]
        
        try:
            # 1. 搜索与跳转
            print(f"[*] 正在跳转产品管理...")
            await page.goto("https://crm.xiaoman.cn/product", wait_until="commit")
            await asyncio.sleep(2)
            await auto_clean_modals(page)

            search_input = page.locator(".ow-fixed-render-name-inner", has_text="编号/型号/名称").first
            await search_input.click()
            await page.keyboard.press("Control+A")
            await page.keyboard.press("Backspace")
            await page.keyboard.type(product_id)
            await page.keyboard.press("Enter")

            await asyncio.sleep(3) 
            target_link = page.locator(".product-name-link").first
            await target_link.wait_for(state="attached", timeout=10000)

            async with context.expect_page(timeout=10000) as new_page_info:
                await target_link.evaluate("el => el.click()")
            new_page = await new_page_info.value
            href = new_page.url
            await new_page.close()

            if href:
                final_url = re.sub(r"tab=[^&]+", "tab=inquiryHistoryTabPane", href)
                if "tab=" not in final_url:
                    final_url += ("&" if "?" in final_url else "?") + "tab=inquiryHistoryTabPane"
                
                print(f"[+] 跳转至询价历史...")
                await page.goto(final_url)
                
                print(f"[*] 等待历史数据加载...")
                await asyncio.sleep(4) 
                await auto_clean_modals(page)

                # ==========================================
                # 恢复：100% 准确的历史判定逻辑
                # ==========================================
                has_history = await page.evaluate("""() => {
                    const emptySelectors = ['.ant-empty', '.ant-empty-image', '.no-data'];
                    for (let s of emptySelectors) {
                        if (document.querySelector(s)) return false;
                    }
                    const text = document.body.innerText;
                    if (text.includes('暂无数据') || text.includes('暂无记录') || text.includes('没有找到符合条件的记录')) {
                        return false;
                    }
                    return true;
                }""")

                if not has_history:
                    print(f"[-] 【结果判定】: 产品 {product_id} 无询价历史，流程安全结束。")
                    return # 判定没有记录，直接退出当前产品处理

                # ==========================================
                # 有记录时，继续拦截新标签页执行下载
                # ==========================================
                print(f"[+] 发现询价历史！锁定任务编号，准备跳转详情页...")
                jump_icon = page.locator(".jump-link .new-tab-icon").first
                
                try:
                    async with context.expect_page(timeout=20000) as task_page_info:
                        await jump_icon.click(force=True)
                    
                    task_page = await task_page_info.value
                    print(f"[+] 成功拦截任务详情页: {task_page.url}")
                    
                    await task_page.wait_for_load_state("domcontentloaded")
                    await asyncio.sleep(4) 
                    
                    print(f"[*] 正在寻找 Excel 下载按钮...")
                    found_dl = await task_page.evaluate("""() => {
                        const nodes = Array.from(document.querySelectorAll('a, span, button'));
                        const btn = nodes.find(n => n.innerText && n.innerText.trim() === '下载');
                        if (btn) { btn.id = 'final-download-node'; return true; }
                        return false;
                    }""")

                    if found_dl:
                        print(f"[*] 发现下载按钮，正在保持原文件名下载...")
                        async with task_page.expect_download(timeout=30000) as download_info:
                            await task_page.locator("#final-download-node").click(force=True)
                        
                        download = await download_info.value
                        
                        # 使用服务器建议的原始文件名
                        original_filename = download.suggested_filename
                        save_path = os.path.join(DOWNLOAD_DIR, original_filename)
                        
                        await download.save_as(save_path)
                        print(f"[SUCCESS] 附件下载完成！")
                        print(f"[SUCCESS] 原始文件名保存至: {save_path}")
                    else:
                        print(f"[!] 详情页内未发现“下载”按钮。")
                    
                    await task_page.close()
                    
                except Exception as task_err:
                    print(f"[!] 跳转任务页或下载过程出错: {task_err}")

            await asyncio.sleep(5)
        except Exception as e:
            print(f"[ERROR] 执行异常: {e}")
        finally:
            await context.close()

if __name__ == "__main__":
    target_id = sys.argv[1] if len(sys.argv) > 1 else "HBB6969"
    asyncio.run(run_product_task(target_id))