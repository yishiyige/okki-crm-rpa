import asyncio
import os
from playwright.async_api import async_playwright

async def check_login():
    # 强制指定一个干净的自动化路径
    # 注意：这里换成了一个独立路径，第一次运行会是“未登录”状态
    user_data = os.path.join(os.environ['LOCALAPPDATA'], r"Microsoft\Edge\User Data\Automation")
    edge_path = r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe"

    async with async_playwright() as p:
        print(f"[*] 正在启动 Edge 自动化实例...")
        print(f"[*] 配置文件路径: {user_data}")
        
        try:
            context = await p.chromium.launch_persistent_context(
                user_data_dir=user_data,
                executable_path=edge_path,
                headless=False,
                # 移除可能冲突的 args，只保留基本的
                args=["--no-first-run"]
            )
            
            page = context.pages[0]
            await page.goto("https://crm.xiaoman.cn/product")
            
            print("\n" + "="*30)
            print("请在弹出的浏览器中完成登录。")
            print("登录成功并看到产品页面后，回到这里按回车。")
            print("="*30)
            
            input(">>> 完成后按回车键保存 Session 并退出...")
            await context.close()
            
        except Exception as e:
            print(f"\n[!] 运行中出错: {e}")

if __name__ == "__main__":
    asyncio.run(check_login())